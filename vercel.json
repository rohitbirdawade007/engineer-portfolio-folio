{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://my-new-port-yg49.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://my-new-port-yg49.onrender.com/uploads/$1"
    },
    {
      "source": "/((?!api|uploads).*)",
      "destination": "/index.html"
    }
  ]
}
