{
  "version": 2,
  "cleanUrls": true,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://my-new-port-yg49.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://my-new-port-yg49.onrender.com/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
